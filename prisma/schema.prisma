// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  address       String?   @unique
  name          String?
  bio           String?
  image         String?
  role          String    @default("LISTENER")
  payoutAddress String?
  twitter       String?
  instagram     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Real Royalty Balances (in ETH/Wei)
  royaltyBalance Float     @default(0)
  totalPaidOut   Float     @default(0)
  
  accounts      Account[]
  sessions      Session[]
  media         Media[]
  nfts          NFT[]
  playlists     Playlist[]
  transactions  Transaction[]
  streams       Stream[]
  
  subscriptions Subscription[]
  comments      Comment[]
  likes         Like[]
  followers     Follow[] @relation("following")
  following     Follow[] @relation("follower")
  artistSettlements ArtistSettlement[]
}

model Media {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String    // "audio" or "video"
  url           String    // IPFS hash or local path
  thumbnailUrl  String?
  genre         String?
  producer      String?
  releaseYear   Int?
  scheduledRelease DateTime?
  album         String?
  isGated       Boolean   @default(false)
  price         Float?    // Price in ETH for the NFT
  playCount     Int       @default(0)
  
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  nft           NFT?
  playlistItems PlaylistItem[]
  streams       Stream[]
  comments      Comment[]
  likes         Like[]
  createdAt     DateTime  @default(now())
}

model NFT {
  id            String    @id @default(cuid())
  tokenId       String?   @unique
  contractAddr  String?
  metadataUrl   String?
  ownerAddress  String
  
  mediaId       String    @unique
  media         Media     @relation(fields: [mediaId], references: [id])
  
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime  @default(now())
}

model Playlist {
  id            String    @id @default(cuid())
  title         String
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         PlaylistItem[]
  createdAt     DateTime  @default(now())
}

model PlaylistItem {
  id            String    @id @default(cuid())
  playlistId    String
  playlist      Playlist  @relation(fields: [playlistId], references: [id])
  mediaId       String
  media         Media     @relation(fields: [mediaId], references: [id])
  order         Int
}

model Transaction {
  id            String    @id @default(cuid())
  hash          String    @unique
  type          String    // "mint", "transfer", "royalty"
  amount        Float?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model Stream {
  id            String    @id @default(cuid())
  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId       String
  media         Media     @relation(fields: [mediaId], references: [id])
  duration      Int       // seconds played
  isSettled     Boolean   @default(false)
  timestamp     DateTime  @default(now())
}

model GlobalSettings {
  id            String    @id @default("global")
  platformFee   Float     @default(2.5) // Percentage
  defaultRoyalty Float    @default(5.0) // Percentage
  updatedAt     DateTime  @updatedAt
}

// NextAuth models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier          String    @default("premium")
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  txnHash       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Comment {
  id            String    @id @default(cuid())
  content       String
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId       String
  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
}

model Like {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaId       String
  media         Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([userId, mediaId])
}

model Follow {
  id            String    @id @default(cuid())
  followerId    String
  follower      User      @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId   String
  following     User      @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([followerId, followingId])
}

model RoyaltySettlement {
  id            String    @id @default(cuid())
  totalPool     Float     // Total ETH available for distribution
  totalStreams  Int       // Total streams processed in this settlement
  processedAt   DateTime  @default(now())
  settlements   ArtistSettlement[]
}

model ArtistSettlement {
  id                String    @id @default(cuid())
  royaltySettlementId String
  royaltySettlement RoyaltySettlement @relation(fields: [royaltySettlementId], references: [id], onDelete: Cascade)
  artistId          String
  artist            User      @relation(fields: [artistId], references: [id])
  streamsCount      Int       // Streams by this artist in this settlement
  payoutAmount      Float     // Amount paid to this artist
  isPaid            Boolean   @default(false)
  createdAt         DateTime  @default(now())

  @@unique([royaltySettlementId, artistId])
}
